        "type": "https",
        "server": "8.8.8.8",
        "detour": "🚀 Default"
      },
      {
        "tag": "cn_dns",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "fake_dns",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      {
        "clash_mode": "direct",
        "server": "cn_dns"
      },
      {
        "clash_mode": "global",
        "server": "fake_dns"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain_suffix": [
              ".cn"
            ]
          },
          {
            "domain_keyword": [
              "stun",
              "turn"
            ]
          },
          {
            "rule_set": "cnsite"
          }
        ],
        "server": "cn_dns"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fake_dns",
        "rewrite_ttl": 1
      }
    ]
  },
